import os
import sqlite3

# امتدادات المكتبات المستهدفة
LIB_EXTENSIONS = {'.dll', '.so', '.jar', '.pyc', '.pyd'}
LIB_FOLDERS = {'node_modules', 'site-packages', 'lib', 'bin'}

def create_database():
    conn = sqlite3.connect('libs_index.db')
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS libraries 
                 (name TEXT, path TEXT, type TEXT)''')
    conn.commit()
    return conn

def scan_system(root_path, conn):
    cursor = conn.cursor()
    print(f"جاري المسح في: {root_path} ...")
    
    for root, dirs, files in os.walk(root_path):
        # البحث عن مجلدات المكتبات الشهيرة
        for d in dirs:
            if d in LIB_FOLDERS:
                cursor.execute("INSERT INTO libraries VALUES (?, ?, ?)", (d, root, 'Folder'))
        
        # البحث عن ملفات المكتبات المنفردة
        for f in files:
            ext = os.path.splitext(f)[1].lower()
            if ext in LIB_EXTENSIONS:
                cursor.execute("INSERT INTO libraries VALUES (?, ?, ?)", (f, root, 'File'))
    
    conn.commit()
    print("تم الانتهاء من الفهرسة!")

# تشغيل التجربة على مجلد محدد أولاً (لتجنب البطء)
db_conn = create_database()
scan_system('C:\\', db_conn) # أو '/' للينكس